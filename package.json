{
  "name": "kali-remote-gui",
  "version": "1.3.0",
  "description": "Professional mobile interface for Kali Linux penetration testing tools",
  "private": true,
  "author": "Kali Remote GUI Contributors",
  "license": "MIT",
  "homepage": "https://github.com/notconnector/kali-remote-gui",
  "repository": {
    "type": "git",
    "url": "https://github.com/notconnector/kali-remote-gui.git"
  },
  "bugs": {
    "url": "https://github.com/notconnector/kali-remote-gui/issues"
  },
  "keywords": [
    "kali-linux",
    "penetration-testing",
    "react-native",
    "android",
    "security-tools",
    "websocket"
  ],
  "scripts": {
    "android": "react-native run-android",
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint src/ --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint src/ --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write 'src/**/*.{js,jsx,ts,tsx,json,css,md}'",
    "format:check": "prettier --check 'src/**/*.{js,jsx,ts,tsx,json,css,md}'",
    "bundle:android": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res",
    "build:android": "cd android && ./gradlew assembleRelease",
    "clean:android": "cd android && ./gradlew clean",
    "prepare": "husky install"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.21.0",
    "@react-navigation/bottom-tabs": "6.5.11",
    "@react-navigation/native": "6.1.10",
    "@react-navigation/native-stack": "6.9.17",
    "eventemitter3": "5.0.1",
    "react": "18.2.0",
    "react-native": "0.73.6",
    "react-native-linear-gradient": "2.8.3",
    "react-native-safe-area-context": "4.8.2",
    "react-native-screens": "3.29.0"
  },
  "devDependencies": {
    "@babel/core": "7.23.9",
    "@babel/preset-env": "7.23.9",
    "@babel/runtime": "7.23.9",
    "@react-native-community/cli": "12.3.2",
    "@react-native-community/cli-platform-android": "12.3.2",
    "@react-native/babel-preset": "0.73.21",
    "@react-native/eslint-config": "0.73.2",
    "@react-native/metro-config": "0.73.5",
    "@react-native/typescript-config": "0.73.1",
    "@types/react": "18.2.0",
    "@types/react-native": "0.73.0",
    "@typescript-eslint/eslint-plugin": "^5.57.1",
    "@typescript-eslint/parser": "^5.57.1",
    "babel-jest": "29.7.0",
    "eslint": "8.57.0",
    "husky": "9.0.11",
    "jest": "29.7.0",
    "lint-staged": "15.2.2",
    "prettier": "3.2.5",
    "react-test-renderer": "18.2.0",
    "typescript": "5.3.3"
  },
  "engines": {
    "node": ">=18"
  },
  "jest": {
    "preset": "react-native"
  }
}
